# vpn-server 环境变量配置（示例）
#
# 本文件由 .deb / .rpm 安装到 /etc/vpn-server/vpn-server.env，
# 并被 systemd 单元 vpn-server.service 通过 EnvironmentFile 加载。
# 安装包会将其标记为 config 文件，升级时不会覆盖你的修改。
#
# 修改后执行：sudo systemctl restart vpn-server

# 监听地址（HTTP 管理后台 + API）。默认 0.0.0.0:8080。
VPN_BIND_ADDR=0.0.0.0:8080

# SQLite 数据库连接串。数据目录由 systemd StateDirectory 管理（/var/lib/vpn-server）。
DATABASE_URL=sqlite:///var/lib/vpn-server/vpn.db?mode=rwc

# 数据目录（JWT 密钥等持久化文件）。默认 ./data；生产环境指向 /var/lib/vpn-server。
VPN_DATA_DIR=/var/lib/vpn-server

# 是否启用内置 HTTPS（ACME）。启用时必须设置 VPN_DOMAIN。
VPN_HTTPS=false

# 公网域名（启用 HTTPS / 推导 WireGuard endpoint 时使用）。
#VPN_DOMAIN=vpn.example.com

# WireGuard 数据平面子网（CIDR）。默认 10.8.0.0/24。
VPN_SUBNET=10.8.0.0/24

# WireGuard 监听端口（UDP）。默认 51820。
VPN_LISTEN_PORT=51820

# 客户端连接用的 WireGuard endpoint（host:port）。
# 缺省时由 VPN_DOMAIN:VPN_LISTEN_PORT 推导，否则需显式设置为公网地址。
#VPN_ENDPOINT=vpn.example.com:51820

# 审计日志保留天数。默认 180。
VPN_AUDIT_RETENTION_DAYS=180

# 日志级别（tracing EnvFilter）。
RUST_LOG=info,sqlx=warn
